# Copy to .env for examples (from examples/ dir: cp env.sample .env)

# Logging: LOG_LEVEL=error|warn|info|debug (default: error = minimal output)
# LOG_LEVEL=error

# Temporal (TaskQueue required, unique per agent. For multiple agents use WithInstanceId or different TaskQueues.)
TEMPORAL_HOST=localhost
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASKQUEUE=temporal-agents-go

# LLM (openai | anthropic)
LLM_PROVIDER=openai
LLM_APIKEY=
LLM_MODEL=gpt-4o
LLM_BASEURL=https://api.openai.com/v1

# Optional: Serper API (for search tool - 2,500 free queries at serper.dev)
# SERPER_API_KEY=
